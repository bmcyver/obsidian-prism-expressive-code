{
  "name": "obsidian-prism-expressive-code",
  "private": true,
  "scripts": {
    "dev": "vite build --mode=development --watch",
    "build": "tsc -noEmit -skipLibCheck && vite build --mode=production",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/hast": "^3.0.5",
    "@types/node": "^26.1.1",
    "@types/prismjs": "^1.26.6",
    "eslint": "^10.7.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "prettier": "^3.9.5",
    "prismjs": "^1.30.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@expressive-code/core": "workspace:*",
    "@expressive-code/plugin-collapsible-sections": "^0.43.1",
    "@expressive-code/plugin-frames": "^0.43.1",
    "@expressive-code/plugin-line-numbers": "^0.43.1",
    "@expressive-code/plugin-text-markers": "^0.43.1",
    "@lezer/common": "^1.5.2",
    "hast-util-to-dom": "^4.0.1",
    "obsidian": "^1.13.1",
    "shiki": "^4.3.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "download"
    }
  }
}
