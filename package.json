{
  "name": "obsidian-prism-expressive-code",
  "version": "0.2.2",
  "description": "An Obsidian plugin that provides syntax highlighting using Prism and Expressive Code.",
  "main": "main.js",
  "scripts": {
    "dev": "vite build --mode=development --watch",
    "build": "tsc -noEmit -skipLibCheck && vite build --mode=production",
    "prettier": "prettier --write .",
    "lint": "eslint ."
  },
  "private": true,
  "author": "bmcyver",
  "license": "MIT",
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.1",
    "@types/prismjs": "^1.26.6",
    "eslint": "10.4.0",
    "eslint-plugin-obsidianmd": "0.3.0",
    "obsidian": "latest",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "dependencies": {
    "@expressive-code/core": "workspace:*",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-frames": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@expressive-code/plugin-text-markers": "^0.42.0",
    "shiki": "^4.1.0",
    "hast-util-to-dom": "^4.0.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/common": "^1.5.2"
  }
}
