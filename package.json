{
	"name": "shiki-highlighter",
	"version": "0.7.7",
	"description": "Highlight code blocks with Shiki.",
	"main": "main.js",
	"scripts": {
		"dev": "vite build --mode=development --watch",
		"build": "pnpm typecheck && vite build --mode=production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"format": "prettier --write packages/**",
		"lint": "eslint --max-warnings=0 packages/**",
		"check": "pnpm format:check && pnpm typecheck && pnpm lint",
		"check:fix": "pnpm format && pnpm typecheck && pnpm lint:fix"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.0",
		"@eslint/js": "^9.39.4",
		"@expressive-code/core": "^0.42.0",
		"@expressive-code/plugin-collapsible-sections": "^0.42.0",
		"@expressive-code/plugin-frames": "^0.42.0",
		"@expressive-code/plugin-line-numbers": "^0.42.0",
		"@expressive-code/plugin-text-markers": "^0.42.0",
		"@lezer/common": "^1.5.2",
		"@types/hast": "^3.0.4",
		"@types/node": "^22.19.19",
		"@types/prismjs": "^1.26.6",
		"hast-util-to-dom": "^4.0.1",
		"obsidian": "latest",
		"prettier": "^3.8.3",
		"shiki": "^4.1.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.13",
		"vite-plugin-node-polyfills": "^0.28.0"
	}
}
